# Copy this file to backend/.env and fill in real values.
# Do NOT commit backend/.env to version control (already in .gitignore).

# --- App ---
APP_ENV=development
APP_NAME=Luminary
LOG_LEVEL=INFO

# --- Database ---
# Matches docker-compose.yml defaults.
DATABASE_URL=postgresql+psycopg://luminary:luminary_dev_only@localhost:5432/luminary

# --- Auth ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=replace-me-with-32-bytes-of-random
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# --- LLM ---
# Primary: Claude. Fallback: OpenAI. Set at least one.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_DAILY_TOKEN_BUDGET=200000

# --- External content APIs ---
GOOGLE_BOOKS_API_KEY=
TMDB_API_KEY=
OMDB_API_KEY=
GUARDIAN_API_KEY=
YOUTUBE_API_KEY=

# --- CORS ---
# Comma-separated list of allowed origins for the frontend.
CORS_ORIGINS=http://localhost:5173
